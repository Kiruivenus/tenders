# =========================================================================
# ZOHO MAIL SMTP CONFIGURATION
# =========================================================================
# To receive emails, configure your Zoho Mail credentials below.
# Note: You must generate a "Device App Password" from your Zoho Account settings
# (Security > App Passwords) rather than using your login password.
# =========================================================================

SMTP_HOST=smtp.zoho.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tenders@dolagroup.info
SMTP_PASS=YOUR_ZOHO_APP_PASSWORD

# Target procurement mailbox where new submissions are sent
RECEIVER_EMAIL=tenders@dolagroup.info

# Application Port
PORT=3000
